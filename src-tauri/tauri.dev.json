{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Ambit (Dev)",
    "version": "0.1.0",
    "identifier": "com.ambit.dev",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1421",
        "beforeDevCommand": "pnpm run dev",
        "beforeBuildCommand": "pnpm run build"
    },
    "app": {
        "windows": [
            {
                "title": "Ambit (DEV) | Local AI Workspace",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false,
                "decorations": false,
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": null,
            "capabilities": [
                "default"
            ],
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "**",
                    "C:\\**",
                    "D:\\**",
                    "$HOME\\**"
                ]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}