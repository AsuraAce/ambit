{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ambit",
  "version": "0.5.0",
  "identifier": "com.ambit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ambit | Local AI Workspace",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false,
        "backgroundColor": "#09090b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: http://asset.localhost https://asset.localhost https://grainy-gradients.vercel.app; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://generativelanguage.googleapis.com;",
      "capabilities": [
        "default"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2QjlGRkJGQTg4QUFBMQpSV1NocW9qNis1OXJDM3Juc2pkbi9JbHJJdzZ4NCtWb2N1OHk2eFhuVTJqOG4xcWlyemRHREpZNAo=",
      "endpoints": [
        "https://github.com/AsuraAce/ambit/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
