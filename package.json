{
  "name": "ambit",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "app:dev": "tauri dev --config src-tauri/tauri.dev.json",
    "app:build": "pnpm run verify:release && tauri build --ci --bundles nsis msi",
    "app:build:no-bundle": "pnpm run verify:release && tauri build --ci --no-bundle",
    "app:build:nsis": "pnpm run verify:release && tauri build --ci --bundles nsis",
    "bindings:generate": "cargo run --manifest-path src-tauri/Cargo.toml --bin export_bindings -- src/bindings.ts",
    "bindings:check": "node ./scripts/check-bindings.mjs",
    "check:versions": "node ./scripts/check-version-consistency.mjs",
    "typecheck": "tsc --noEmit",
    "verify:release": "pnpm run check:versions && pnpm run bindings:check && pnpm run typecheck && pnpm run test:run && pnpm run test:rust",
    "audit:prod": "pnpm audit --prod",
    "audit:rust": "node ./scripts/audit-rust.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:rust": "cd src-tauri && cross-env SKIP_TAURI_BUILD=1 cargo test --lib",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.4",
    "@tauri-apps/plugin-sql": "^2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "clsx": "^2.1.0",
    "framer-motion": "^12.25.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "9",
    "recharts": "^3.4.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.8.2",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
