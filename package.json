{
  "name": "ambit",
  "private": true,
  "description": "High-performance local AI image manager for large AI-generated image libraries.",
  "version": "0.8.0",
  "type": "module",
  "author": "AsuraAce",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/AsuraAce/ambit.git"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:guard": "node ./scripts/check-build-output.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts --max-warnings=0",
    "preview": "vite preview",
    "tauri": "tauri",
    "app:dev": "tauri dev --config src-tauri/tauri.dev.json",
    "app:build": "corepack pnpm run verify:release && tauri build --ci --bundles nsis msi",
    "app:build:no-bundle": "corepack pnpm run verify:release",
    "app:build:nsis": "corepack pnpm run verify:release && tauri build --ci --bundles nsis",
    "tauri:check": "tauri build --ci --no-bundle",
    "bindings:generate": "cargo run --manifest-path src-tauri/Cargo.toml --bin export_bindings -- src/bindings.ts",
    "bindings:check": "node ./scripts/check-bindings.mjs",
    "check:versions": "node ./scripts/check-version-consistency.mjs",
    "check:pr-title": "node ./scripts/check-pr-title.mjs",
    "typecheck": "tsc --noEmit",
    "verify:release": "corepack pnpm run check:versions && corepack pnpm run bindings:check && corepack pnpm run lint && corepack pnpm run typecheck && corepack pnpm run build:guard && corepack pnpm run coverage && corepack pnpm run test:rust && corepack pnpm run tauri:check",
    "audit:prod": "pnpm audit --prod",
    "audit:rust": "node ./scripts/audit-rust.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:rust": "node ./scripts/test-rust.mjs",
    "coverage": "vitest run --coverage --coverage.provider=istanbul --maxWorkers=1"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-shell": "2.3.5",
    "@tauri-apps/plugin-sql": "2.4.0",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@tauri-apps/plugin-window-state": "2.4.1",
    "clsx": "^2.1.0",
    "framer-motion": "^12.42.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "10",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-istanbul": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
